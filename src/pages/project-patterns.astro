---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projectPatterns } from '../data/knowledge';
---
<BaseLayout title="项目证据 - PersonalLib" rootPrefix="../" description="AIoT 与智能硬件产品经理项目证据，整理平台、移动端应用、边缘智能和设备上云经验。">
  <section class="page-hero">
    <p class="eyebrow">Project Evidence</p>
    <h1>项目证据</h1>
    <p>把项目经历整理成岗位可判断的信息：角色、阶段、负责范围、能力证明和可迁移价值。</p>
  </section>

  <section class="pattern-detail pattern-detail--evidence">
    {projectPatterns.map((pattern) => (
      <article>
        <div class="pattern-detail__head">
          <span>{pattern.stage}</span>
          <h2>{pattern.title}</h2>
          <p>{pattern.summary}</p>
        </div>
        <div class="flow-row flow-row--large">
          {pattern.flow.map((step) => <span>{step}</span>)}
        </div>
        <div class="project-proof-grid">
          <div>
            <strong>角色</strong>
            <p>{pattern.role}</p>
          </div>
          <div>
            <strong>岗位相关性</strong>
            <p>{pattern.jdFit}</p>
          </div>
        </div>
        <ul class="evidence-list">
          {pattern.evidence.map((item) => <li>{item}</li>)}
        </ul>
        <div class="chip-list">
          {pattern.focus.map((item) => <b>{item}</b>)}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
