---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projectPatterns } from '../data/knowledge';
---
<BaseLayout title="产品切面 - PersonalLib" rootPrefix="../" description="AIoT 与智能硬件产品经理项目切面，整理平台、移动端应用、边缘智能和设备上云经验。">
  <section class="page-hero">
    <p class="eyebrow">Selected work</p>
    <h1>产品切面</h1>
    <p>这些项目的共同点不是行业标签，而是复杂协作：硬件有边界，软件有节奏，现场有反馈。</p>
  </section>

  <section class="pattern-detail pattern-detail--evidence">
    {projectPatterns.map((pattern) => (
      <article>
        <div class="pattern-detail__head">
          <span>{pattern.stage}</span>
          <h2>{pattern.title}</h2>
          <p>{pattern.summary}</p>
        </div>
        <div class="flow-row flow-row--large">
          {pattern.flow.map((step) => <span>{step}</span>)}
        </div>
        <div class="project-proof-grid">
          <div>
            <strong>角色</strong>
            <p>{pattern.role}</p>
          </div>
          <div>
            <strong>留下的判断</strong>
            <p>{pattern.lesson}</p>
          </div>
        </div>
        <ul class="evidence-list">
          {pattern.evidence.map((item) => <li>{item}</li>)}
        </ul>
        <div class="chip-list">
          {pattern.focus.map((item) => <b>{item}</b>)}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
